# Copy this file to `.env` and fill in absolute paths to your local files.
# .env is gitignored — never commit secrets.

# Private SSH key matching the keypair you uploaded to OpenStack Horizon.
SSH_KEY_PATH=/home/your-user/.ssh/your-key.pem

# Name of the keypair as registered in OpenStack Horizon (Compute → Key Pairs).
OPENSTACK_KEY_NAME=your-keypair-name

# OpenStack credentials file (Horizon → API Access → Download OpenStack RC File v3).
OPENRC_PATH=/home/your-user/openrc.sh

# File listing 1–5 GitHub Personal Access Tokens, one per line:
#   GITHUB_TOKEN_1=ghp_xxxxxxxxxxxx
#   GITHUB_TOKEN_2=ghp_xxxxxxxxxxxx   # optional
#   ...
# 1 token is enough for a demo. More tokens (from different GitHub accounts)
# multiply the rate-limit budget — see README.
GITHUB_TOKENS_PATH=/home/your-user/.github_tokens

# How many days of GitHub history the producer should scan.
# Default 365 needs ~150k API calls; for a demo set to 3–7.
DAYS_BACK=7
